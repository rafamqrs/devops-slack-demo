SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token
GITHUB_TOKEN=ghp_your-personal-access-token
PORT=3000

# Socket Mode: não precisa de URL público
# O SLACK_APP_TOKEN (xapp-) é obrigatório para Socket Mode
# Gera em: api.slack.com/apps > Your App > Basic Information > App-Level Tokens
